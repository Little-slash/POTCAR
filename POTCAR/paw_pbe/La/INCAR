system = La2O3 
   NWRITE =      2;   LPETIM=P    write-flag & timer 
   ENCUT   =     300.000
   PREC    =     high 
   ISTART  =     0      job   : 0-new  1-cont  2-samecut
   ICHARG  =     2      charge: 1-file 2-atom  10-const
   ISPIN   =     1      non spin polarized calculation
#  RWIGS  =     0.80 1.05 0.4500
#  LORBIT =      12  
   NELM    =     60;    NELMIN= 2; NELMDL= 0   
   EDIFF   =     1.0E-4 stopping-criterion for ELM(allowed error in total energy,default 10E-4)

 Ionic Relaxation:
   EDIFFG  =     -0.05  stopping-criterion for IOM(Ionic optimization Number),break condition for Ionic relax
   NSW     =     50    number of steps for IOM
   NBLOCK  =     1;     KBLOCK   =   50    inner block; outer block
   IBRION  =     2      ionic relax: 0-MD  1-quasi-New  2-CG  5-frequency cal.
   ISIF    =     2      2-calculate  relax ions, no change cell shape, cell volume
   ISYM    =     2      0-nonsym  1-if VASP runs with US-PP's  2-if PAW data sets are used
   POTIM   =     0.5    time-step for ion-motion
#  TEIN   =     5000.0    initial temperature
#  TEBEG  =     5000.0;   TEEND  =     5000.0 temperature during run
#  SMASS  =     -1    Nose mass-parameter (am)
   GGA     =     PE

 Electronic Relaxation 2
   IALGO   =     38     algorithm 48-RMM, 38-Davison Block
   LDIAG   =     T      sub-space diagonalisation
   LWAVE   =     T 
   LCHARG  =     T 
   LREAL   =     A      real-space projection
   NPAR    =     1

 DOS related values:
   EMIN    =     10.00; EMAX  =  -10.00  energy-range for DOS
   ISMEAR  =     0;     SIGMA =  0.2     broadening in eV -4-tet -1-fermi 0-gaus
   SYMPREC =     0.001 
